rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function ownsPath(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /profile_pictures/{userId}/{fileName} {
      allow read, write: if ownsPath(userId);
    }

    match /user_cvs/{userId}/{fileName} {
      allow read, write: if ownsPath(userId);
    }
  }
}
